# Dependencies
node_modules/
apps/*/node_modules/
apps/*/client/node_modules/
apps/*/server/node_modules/

# Build output
apps/*/client/dist/

# Database files (never commit live data)
apps/*/server/*.db
apps/*/server/*.db-shm
apps/*/server/*.db-wal
*.db
*.db-shm
*.db-wal

# Environment / secrets (NEVER commit these)
.env
apps/*/.env
apps/*/server/.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/

# Claude Code (machine-specific paths, local permissions)
.claude/
