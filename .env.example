# Shared fallback env file for local development.
# Each app can also define its own env file:
# - apps/ncaa/.env
# - apps/f1/.env

# NCAA defaults
NCAA_PORT=3001
NCAA_CLIENT_ORIGIN=http://localhost:5173

# F1 defaults
F1_PORT=3002
F1_CLIENT_ORIGIN=http://localhost:5174
F1_RESULTS_PROVIDER=mock

# App credentials
ADMIN_PASSWORD=changeme
NODE_ENV=development

# NCAA optional AI commentary key
ANTHROPIC_API_KEY=your-anthropic-api-key-here
